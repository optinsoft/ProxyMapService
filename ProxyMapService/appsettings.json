{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "ProxyService": "Information",
            "ProxySession": "Information"
        },
        "Console": {
            "FormatterName": "simple",
            "FormatterOptions": {
                "TimestampFormat": "[yyyy-MM-dd HH:mm:ss] ",
                "UseUtcTimestamp": true
            }
        },
        "WebSocket": {
            "LogLevel": {
                "Default": "Information",
                "ProxyMapService": "Information",
                "ProxySession": "Information",
                "DevTokenLauncher": "None",
                "Microsoft.AspNetCore.Mvc": "Warning",
                "Microsoft.AspNetCore.Hosting": "Warning",
                "Microsoft.AspNetCore.Routing": "Warning",
                "Microsoft.AspNetCore.Cors": "Warning",
                "Microsoft.AspNetCore.SignalR": "Warning",
                "Microsoft.AspNetCore.StaticFiles.StaticFileMiddleware": "Warning",
                "Microsoft.AspNetCore.Authentication.AuthenticationService": "Warning"
            }
        }
    },
    "WebSocketMonitoring": {
        "EventLog": {
            "Enabled": false,
            "MaxEntries": 500,
            "Capture": false
        },
        "TrafficMonitor": {
            "Enabled": false,
            "MaxEntries": 500,
            "LogBody": false,
            "Capture": false
        },
        "QueueCapacity": 10000
    },
    "AllowedHosts": "*",
    "CorsSettings": {
        "AllowedOrigins": [
            "http://localhost:5173"
        ]
    },
    "Security": {
        "AllowOnlyLocalhost": true
    },
    "Authentication": {
        "Jwt": {
            "Enabled": false,
            "Issuer": "your_issuer",
            "Audience": "your_audience",
            "Key": "Your_32-character_secret_JWT_key"
        },
        "DevToken": {
            "Enabled": true
        }
    },
    "Dashboard": {
        "Enabled": true
    },
    "ProxyMappings": [
        {
            "Listen": {
                "Port": 5001,
                "RejectHttpProxy": false,
                "StickyProxyLifetime": 0,
                "Action": "Allow",
                "DecryptSSL": false,
                "SslMode": "Auto",
                "UpstreamSslMode": "Auto",
                "IgnoreHostRules": false
            },
            "Authentication": {
                "Required": false,
                "Verify": false,
                "SetAuthentication": false,
                "RemoveAuthentication": false,
                "ParseUsernameParameters": false,
                "Username": "user",
                "Password": "pass"
            }
        }
    ],
    "HostStats": {
        "Enabled": false,
        "TrafficStats": false
    },
    "DetailedLogging": {
        "LogReading": false,
        "LogSending": false,
        "LogTrafficData": false,
        "LogSslEncodedData": false,
        "LogSslDecodedData": false,
        "LogHttpRequestHeaders": false,
        "LogHttpResponseHeaders": false,
        "LogStep": false
    },
    "HTTP": {
        "UserAgent": "proxymapper"
    },
    "SslClientOptions": {
        "EnabledSslProtocols": "Tls12,Tls13",
        "CheckCertificateRevocation": true
    },
    "SslServerOptions": {
        "EnabledSslProtocols": "Tls12,Tls13",
        "ClientCertificateRequired": false,
        "CheckCertificateRevocation": true
    },
    "Cache": {
        "Enabled": false,
        "DbPath": "c:\\temp\\cache\\proxymap.db",
        "CacheDir": "c:\\temp\\cache\\files"
    },
    "SessionAPI": {
        "Enabled": false,
        "Domain": ""
    }
}
